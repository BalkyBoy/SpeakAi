# Application
NODE_ENV=development
PORT=5000

# Frontend origin(s) allowed for CORS and redirects
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# Database
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/speakai

# JWT secrets (use strong random values in real envs)
JWT_SECRET=replace-with-strong-access-secret
JWT_REFRESH_SECRET=replace-with-strong-refresh-secret

# Redis (for caching / queues, if enabled)
REDIS_HOST=localhost
REDIS_PORT=6379
#REDIS_PASSWORD=

# Email / transactional mail (Resend)
RESEND_API_KEY=your-resend-api-key
FROM_EMAIL=onboarding@resend.dev

